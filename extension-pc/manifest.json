{
  "manifest_version": 3,
  "name": "Novel Studio Connector (PC)",
  "version": "4.0",
  "description": "Auto-extract chapters while user reads",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "externally_connectable": {
    "matches": [
      "*://*.vercel.app/*",
      "*://localhost/*"
    ]
  }
}
